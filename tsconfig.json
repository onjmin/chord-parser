{
	"compilerOptions": {
		"target": "ES2024",
		"module": "ESNext",
		"outDir": "dist",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"moduleResolution": "bundler",
		"verbatimModuleSyntax": true,
		"noEmit": true
	},
	"include": ["src/**/*.ts"]
}
